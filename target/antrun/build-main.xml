<?xml version="1.0" encoding="UTF-8"?>
<project name="maven-antrun-" default="main">
  <target name="main">
    <property environment="env" />
    <condition property="resolved.tomcat.webapps" value="${tomcat.webapps}">
      <isset property="tomcat.webapps" />
    </condition>
    <condition property="resolved.tomcat.webapps" value="C:/Program Files/Apache Software Foundation/Tomcat 9.0/webapps">
      <and>
        <not>
          <isset property="resolved.tomcat.webapps" />
        </not>
        <isset property="env.CATALINA_HOME" />
      </and>
    </condition>
    <fail unless="resolved.tomcat.webapps" message="Tomcat webapps path is not configured. Set -Dtomcat.webapps=... or define CATALINA_HOME." />
    <copy file="C:\dev\immregistries\InteropHub\target/hub.war" todir="${resolved.tomcat.webapps}" overwrite="true" />
  </target>
</project>
